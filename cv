                                      {data.coverLetter.content ? (
                                        <>
                                           <div className="mb-8 page-break-word">
                                              <div className="mb-1 text-right">
                                                <EditableText 
                                                  tagName="span" 
                                                  text={data.coverLetter.letterDate || getPlaceDateStr()} 
                                                  onUpdate={v => setData(p => ({...p, coverLetter: {...p.coverLetter, letterDate: v}}))} 
                                                  placeholder="Contoh: Jakarta, 17 Agustus 2026"
                                                />
                                              </div>
                                           </div>
                                           <LetterContent content={data.coverLetter.content} signatureSrc={data.personal.signature} onUpdate={v => setData(p => ({...p, coverLetter: {...p.coverLetter, content: v}}))} />
                                        </>
                                      ) : (
                                        <div className="flex-1 flex flex-col items-center justify-center opacity-40 border-2 border-dashed border-gray-300 rounded-xl p-10 text-center">
                                            <FileText size={40} className="mb-4"/>
                                            <p>{t.noLetterContent || "Belum ada isi surat lamaran."}</p>
                                            <p>{t.useAiGeneratorTip || "Silakan gunakan fitur AI Generator di panel sebelah kiri."}</p>
                                        </div>
                                      )}
                                    </div>
                                  )
                                ) : (
                                  <>
                                    {tConfig.layout === 'single' && (
                                      <div className="w-full h-full min-h-full flex flex-col relative z-10 bg-transparent" style={{ color: getContrast(tConfig.pageBgColor || '#ffffff') === 'dark' ? '#111827' : '#f9fafb' }}>
                                        <HeaderRenderer />
                                        <div className={`flex-1 ${tConfig.headerType === 'centered-top' ? 'pt-2' : ''}`} style={{ paddingLeft: pm, paddingRight: pm, paddingBottom: pm }}>
                                          {allSections.map((sec, i) => <RenderSection key={sec} sectionName={sec} idx={i} />)}
                                        </div>
                                      </div>
                                    )}

                                    {(tConfig.layout === 'sidebar-left' || tConfig.layout === 'sidebar-left-narrow') && (
                                      <div className="w-full h-full min-h-full flex relative z-10 bg-transparent">
                                        <div className={`${tConfig.layout === 'sidebar-left-narrow' ? 'w-[28%]' : 'w-[32%]'} h-full min-h-full shrink-0 bg-transparent`} style={{ color: getContrast(settings.sidebarColor) === 'dark' ? '#111827' : '#ffffff', padding: pm }}>
                                          <SidebarContent />
                                        </div>
                                        <div className="flex-1 h-full flex flex-col bg-transparent" style={{ padding: pm, color: getContrast(tConfig.pageBgColor || '#ffffff') === 'dark' ? '#111827' : '#f9fafb' }}>
                                          {tConfig.headerType !== 'block-name' && <HeaderRenderer />}
                                          <div className="flex-1 mt-2">
                                            {allSections.filter(sec => !['skills', 'socials'].includes(sec)).map((sec, i) => <RenderSection key={sec} sectionName={sec} idx={i} />)}
                                          </div>
                                        </div>
                                      </div>
                                    )}

                                    {tConfig.layout === 'sidebar-right' && (
                                      <div className="w-full h-full min-h-full flex relative z-10 bg-transparent">
                                        <div className="flex-1 h-full flex flex-col bg-transparent" style={{ padding: pm, color: getContrast(tConfig.pageBgColor || '#ffffff') === 'dark' ? '#111827' : '#f9fafb' }}>
                                          {tConfig.headerType !== 'block-name' && <HeaderRenderer />}
                                          <div className="flex-1 mt-4">
                                            {allSections.filter(sec => !['skills', 'socials'].includes(sec)).map((sec, i) => <RenderSection key={sec} sectionName={sec} idx={i} />)}
                                          </div>
                                        </div>
                                        <div className="w-[32%] h-full min-h-full shrink-0 bg-transparent" style={{ color: getContrast(settings.sidebarColor) === 'dark' ? '#111827' : '#ffffff', padding: pm }}>
                                          <SidebarContent />
                                        </div>
                                      </div>
                                    )}

                                    {tConfig.layout === 'header-split' && (
                                      <div className="w-full h-full min-h-full flex flex-col relative z-10 bg-transparent">
                                         <div style={{ backgroundColor: settings.headbarColor, color: getContrast(settings.headbarColor) === 'dark' ? '#111827' : '#ffffff' }}>
                                           <HeaderRenderer />
                                         </div>
                                         <div className="flex-1 flex w-full h-full bg-transparent">
                                           <div className="flex-1 bg-transparent" style={{ padding: pm, color: getContrast(tConfig.pageBgColor || '#ffffff') === 'dark' ? '#111827' : '#f9fafb' }}>
                                             {allSections.filter(sec => !['skills', 'socials'].includes(sec)).map((sec, i) => <RenderSection key={sec} sectionName={sec} idx={i} />)}
                                           </div>
                                           <div className="w-[30%] h-full min-h-[100%] border-l border-gray-100 bg-transparent" style={{ padding: pm, color: getContrast(settings.sidebarColor || '#ffffff') === 'dark' ? '#111827' : '#f9fafb' }}>
                                              <div className="flex flex-col gap-6 h-full">
                                                {['skills', 'socials'].map(sec => data[sec] && data[sec].length > 0 && <RenderSection key={sec} sectionName={sec} idx={0} />)}
                                                  
                                                {tConfig.hasWaQr && data.personal.phone && activeView === 'cv' && (
                                                    <div className="mt-8 flex flex-col items-center justify-center p-3 border-2 border-dashed border-current rounded-xl opacity-90 mx-auto max-w-max">
                                                      <span className="text-[9px] font-bold uppercase mb-2 tracking-wider text-center">{t.scanForWa || "Scan for WhatsApp"}</span>
                                                      <img 
                                                           src={`https://api.qrserver.com/v1/create-qr-code/?size=${settings.qrSize}x${settings.qrSize}&data=${encodeURIComponent('https://wa.me/' + data.personal.phone.replace(/[^0-9+]/g, '').replace(/^0/, '62').replace(/^\+/, ''))}`} 
                                                           style={{ width: `${settings.qrSize}px`, height: `${settings.qrSize}px` }} 
                                                           className={`rounded ${getContrast(settings.sidebarColor) === 'dark' ? 'mix-blend-multiply' : ''}`} 
                                                           alt="QR WhatsApp" 
                                                      />
                                                    </div>
                                                )}
                                              </div>
                                           </div>
                                         </div>
                                      </div>
                                    )}
                                  </>
                                )}
                              </div>
                           </div>
                         </div>
                    </div>
                 )}
                  </div>
                  
                  {activeView !== 'interview' && mobileTab === 'preview' && (
                    <div className="md:hidden absolute bottom-[76px] left-4 right-4 z-50 flex flex-col gap-2">
                       {activeView === 'letter' && (
                         <label className="bg-white/90 backdrop-blur dark:bg-slate-800/90 p-3 rounded-xl shadow-lg border border-gray-200 dark:border-slate-700 flex items-center justify-between cursor-pointer">
                            <span className="text-xs text-gray-700 dark:text-gray-300 font-bold">{t.useLetterDesignLabel}</span>
                            <div className="relative inline-flex items-center">
                              <input 
                                type="checkbox" 
                                checked={settings.useLetterDesign !== false} 
                                onChange={e => {
                                  const isChecked = e.target.checked;
                                  setSettings({...settings, useLetterDesign: isChecked});
                                  if (data.coverLetter.targetCompany && data.coverLetter.targetPosition && data.coverLetter.content) {
                                      generateCoverLetter(isChecked);
                                  }
                                }} 
                                className="sr-only peer" 
                              />
                              <div className="w-8 h-5 bg-gray-300 dark:bg-slate-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#073d7a] dark:peer-checked:bg-sky-600"></div>
                            </div>
                         </label>
                       )}
                       <button onClick={downloadPDF} disabled={loading.pdf} className="w-full bg-[#073d7a] text-white font-bold py-3.5 rounded-xl flex items-center justify-center gap-2 shadow-lg shadow-sky-600/30">
                         {loading.pdf ? <RefreshCw className="animate-spin" size={18}/> : <Download size={18}/>} 
                         {activeView === 'cv' ? t.downloadBtn : t.downloadLetterBtn}
                       </button>
                    </div>
                  )}
              </div>

               {/* Pemisah Split Screen Khusus Mobile (saat tab format aktif) */}
              {isMobile && mobileTab === 'format' && (
                 <div 
                   onTouchMove={handleSplitTouchMove}
                   className="h-5 bg-gray-200 dark:bg-slate-700 md:hidden flex items-center justify-center active:bg-gray-300 dark:active:bg-slate-600 transition touch-none cursor-row-resize z-[95] shadow-[0_0_10px_rgba(0,0,0,0.1)] relative"
                 >
                   <div className="w-16 h-1.5 bg-gray-400 dark:bg-slate-500 rounded-full pointer-events-none" />
                 </div>
               )}

              {/* Panel Kanan (Format) */}
              {activeView !== 'interview' && (
                <div className={`absolute md:relative top-0 right-0 h-full bg-white/95 dark:bg-slate-800/95 backdrop-blur-md border-l border-gray-200 dark:border-slate-700 shadow-[-5px_0_15px_-5px_rgba(0,0,0,0.1)] flex-col shrink-0 transition-all duration-300 z-[100] 
                  ${mobileTab === 'format' ? 'w-full flex md:w-[320px]' : 'hidden'} 
                  ${isFormatPanelOpen && mobileTab !== 'format' ? 'md:flex md:w-[320px]' : ''} 
                  ${!isFormatPanelOpen && mobileTab !== 'format' ? 'md:flex md:w-0 border-l-0 overflow-hidden' : ''}`}
                  style={(isMobile && mobileTab === 'format') ? { height: `calc(${100 - splitRatio}% - 20px)`, flex: 'none', position: 'relative' } : {}}
                >
                  {renderRightFormatPanel()}
                </div>
              )}
          </div>
            
            {/* Mobile Nav Menu */}
            <div className="md:hidden w-full h-[60px] bg-white/95 dark:bg-slate-900/95 backdrop-blur-md border-t border-gray-200 dark:border-slate-800 fixed bottom-0 left-0 right-0 z-[1000] flex justify-around items-center px-2 pb-safe shadow-[0_-10px_20px_rgba(0,0,0,0.05)]">
               <button 
                  onClick={() => setMobileTab('editor')} 
                  className={`flex-1 flex flex-col items-center justify-center gap-1 transition ${mobileTab === 'editor' ? 'text-[#073d7a] dark:text-sky-400' : 'text-gray-500 dark:text-slate-400'}`}
               >
                  <Edit3 size={20} />
                  <span className="text-[10px] font-bold">{t.editorTab || 'Editor Data'}</span>
               </button>
               <button 
                  onClick={() => {
                    setMobileTab('preview');
                  }} 
                  className={`flex-1 flex flex-col items-center justify-center gap-1 transition ${mobileTab === 'preview' ? 'text-[#073d7a] dark:text-sky-400' : 'text-gray-500 dark:text-slate-400'}`}
               >
                  <Eye size={20} />
                  <span className="text-[10px] font-bold">
                    {activeView === 'letter' ? (t.previewLetterTab || 'Preview Surat') : activeView === 'interview' ? (t.interviewTab || 'Interview') : (t.previewCvTab || 'Preview CV')}
                  </span>
               </button>
               <button 
                  onClick={() => {
                    setMobileTab('format');
                  }} 
                  className={`flex-1 flex flex-col items-center justify-center gap-1 transition ${mobileTab === 'format' ? 'text-[#073d7a] dark:text-sky-400' : 'text-gray-500 dark:text-slate-400'}`}
               >
                  <SlidersHorizontal size={20} />
                  <span className="text-[10px] font-bold">{t.designTab || 'Desain'}</span>
               </button>
            </div>
            
          </div>
        </div>
      );
}
