const DraggableSignature = ({ src, initialX = 0, initialY = 0 }) => {
  const [pos, setPos] = useState({ x: initialX, y: initialY });
  const [size, setSize] = useState(150);
  const [rotation, setRotation] = useState(0);
  const [activeMode, setActiveMode] = useState(null);
  const startRef = useRef({ x: 0, y: 0, startX: 0, startY: 0, startSize: 0, startRot: 0 });
  
  const handlePointerDown = (e, mode) => {
    e.preventDefault();
    e.stopPropagation();
    try {
      e.target.setPointerCapture(e.pointerId);
    } catch (err) {}
    setActiveMode(mode);
    startRef.current = {
      x: e.clientX,
      y: e.clientY,
      startX: pos.x,
      startY: pos.y,
      startSize: size,
      startRot: rotation
    };
  };

  useEffect(() => {
    if (!activeMode) return;
    
    let animationFrameId;
    const handleMove = (e) => {
      e.preventDefault();
      if (animationFrameId) cancelAnimationFrame(animationFrameId);
      animationFrameId = requestAnimationFrame(() => {
        const dx = e.clientX - startRef.current.x;
        const dy = e.clientY - startRef.current.y;

        if (activeMode === 'drag') {
          setPos({ x: startRef.current.startX + dx, y: startRef.current.startY + dy });
        } else if (activeMode === 'resize') {
          setSize(Math.max(50, startRef.current.startSize + dx));
        } else if (activeMode === 'rotate') {
          setRotation(startRef.current.startRot + dx * 0.5);
        }
      });
    };
    
    const handleUp = (e) => {
      e.preventDefault();
      try {
        e.target.releasePointerCapture(e.pointerId);
      } catch (err) {}
      setActiveMode(null);
    };

    window.addEventListener('pointermove', handleMove, { passive: false });
    window.addEventListener('pointerup', handleUp);
    return () => {
      if (animationFrameId) cancelAnimationFrame(animationFrameId);
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleUp);
    };
  }, [activeMode]);

  return (
    <div
      style={{
        position: 'absolute',
        left: `${pos.x}px`,
        top: `${pos.y}px`,
        width: `${size}px`,
        transform: `rotate(${rotation}deg)`,
        transformOrigin: 'center center',
        cursor: activeMode === 'drag' ? 'grabbing' : 'grab',
        zIndex: 50,
        touchAction: 'none',
        willChange: 'left, top, width, transform'
      }}
      className="group touch-none page-break-word"
      onPointerDown={(e) => handlePointerDown(e, 'drag')}
    >
      <img src={src} alt="Tanda Tangan" className="w-full h-auto object-contain pointer-events-none mix-blend-multiply" />
      <div data-html2canvas-ignore="true" className="absolute -inset-2 border border-dashed border-[#073d7a] opacity-0 group-hover:opacity-100 transition pointer-events-none"></div>
      <div
        data-html2canvas-ignore="true"
        className="absolute -top-6 left-1/2 -translate-x-1/2 w-6 h-6 bg-[#073d7a] rounded-full text-white flex items-center justify-center cursor-ew-resize opacity-0 group-hover:opacity-100 transition shadow-md touch-none"
        onPointerDown={(e) => handlePointerDown(e, 'rotate')}
        title="Putar"
      >
        <RefreshCw size={12} />
      </div>
      <div
        data-html2canvas-ignore="true"
        className="absolute -bottom-2 -right-2 w-6 h-6 bg-[#073d7a] rounded-full text-white flex items-center justify-center cursor-nwse-resize opacity-0 group-hover:opacity-100 transition shadow-md touch-none"
        onPointerDown={(e) => handlePointerDown(e, 'resize')}
        title="Ubah Ukuran"
      >
        <Maximize2 size={12} className="rotate-90" />
      </div>
    </div>
  );
};

const EditableText = React.memo(({ text, onUpdate, tagName: Tag = 'span', className = '', style = {}, placeholder = '' }) => {
  const textRef = useRef(null);

  useEffect(() => {
    if (textRef.current && textRef.current.innerHTML !== (text || '')) {
      textRef.current.innerHTML = text || '';
    }
  }, [text]);

  const handleBlur = (e) => {
    if (e.relatedTarget && e.relatedTarget.closest('[data-format-panel="true"]')) {
      return;
    }
    
    if (textRef.current) {
      const currentHTML = textRef.current.innerHTML;
      if (currentHTML !== text) {
        onUpdate(currentHTML);
      }
    }
  };

  const handleKeyDown = (e) => {};

  return (
    <Tag
      ref={textRef}
      contentEditable
      suppressContentEditableWarning
      onBlur={handleBlur}
      onKeyDown={handleKeyDown}
      className={`outline-none hover:outline-dashed hover:outline-1 hover:outline-sky-400/50 focus:outline-[#073d7a] focus:outline focus:outline-2 rounded-sm transition-all cursor-text empty:before:content-[attr(data-placeholder)] empty:before:text-gray-400 ${className}`}
      style={style}
      data-placeholder={placeholder}
      dangerouslySetInnerHTML={{ __html: text }}
    />
  );
}, (prev, next) => {
  return prev.text === next.text && 
         prev.className === next.className && 
         JSON.stringify(prev.style) === JSON.stringify(next.style) &&
         prev.placeholder === next.placeholder;
});

const LetterContent = ({ content, signatureSrc, className = "", onUpdate }) => {
  const matchRegex = /(Hormat saya,?\s*|Hormat kami,?\s*|Sincerely,?\s*|Regards,?\s*)/i;
  const parts = content.split(matchRegex);

  if (parts.length >= 3 && signatureSrc) {
    const after = parts.pop();
    const salutation = parts.pop(); 
    const before = parts.join(''); 

    return (
      <div className={`flex-1 whitespace-pre-wrap text-justify relative ${className}`} style={{ lineHeight: 1.3 }}>
        <EditableText tagName="div" text={before} onUpdate={v => onUpdate(v + salutation + after)} />
        <EditableText tagName="div" className="page-break-word mt-4" text={salutation} onUpdate={v => onUpdate(before + '\n\n' + v + after)} />
        <div className="relative h-2 w-full block my-2 z-50 page-break-word">
           <DraggableSignature src={signatureSrc} initialX={20} initialY={10} />
        </div>
        <EditableText tagName="div" className="page-break-word mt-8" text={after} onUpdate={v => onUpdate(before + salutation + v)} />
      </div>
    );
  }

  return (
    <div className={`flex-1 whitespace-pre-wrap text-justify relative flex flex-col ${className}`} style={{ lineHeight: 1.3 }}>
      <EditableText tagName="div" className="flex-1" text={content} onUpdate={onUpdate} />
      {signatureSrc && (
        <div className="relative h-2 w-full block my-2 z-50 page-break-word">
          <DraggableSignature src={signatureSrc} initialX={20} initialY={10} />
        </div>
      )}
    </div>
  );
};

function useDataHistory(initialState) {
  const [past, setPast] = useState([]);
  const [present, setPresent] = useState(initialState);
  const [future, setFuture] = useState([]);
  const presentRef = useRef(initialState);
  const historyTimer = useRef(null);

  const set = useCallback((action) => {
    const current = presentRef.current;
    const newState = typeof action === 'function' ? action(current) : action;
    if (newState === current) return;
    
    setPresent(newState);
    presentRef.current = newState;
    
    clearTimeout(historyTimer.current);
    historyTimer.current = setTimeout(() => {
        setPast(p => {
            if (p.length > 0 && p[p.length - 1] === current) return p;
            return [...p.slice(-15), current];
        });
        setFuture([]);
    }, 800); 
  }, []);

  const undo = useCallback(() => {
    if (past.length === 0) return;
    const previous = past[past.length - 1];
    setPast(past.slice(0, past.length - 1));
    setFuture(f => [presentRef.current, ...f]);
    setPresent(previous);
    presentRef.current = previous;
  }, [past]);

  const redo = useCallback(() => {
    if (future.length === 0) return;
    const next = future[0];
    setPast(p => [...p, presentRef.current]);
    setPresent(next);
    presentRef.current = next;
    setFuture(future.slice(1));
  }, [future, past]);

  return [present, set, undo, redo, past.length > 0, future.length > 0];
}

