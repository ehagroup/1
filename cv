    setData(p => {
        const newArr = [...p[type]];
        if (direction === 'up' && index > 0) {
            [newArr[index - 1], newArr[index]] = [newArr[index], newArr[index - 1]];
        } else if (direction === 'down' && index < newArr.length - 1) {
