const CropModal = ({ imageSrc, onCrop, onClose }) => {
  const [zoom, setZoom] = useState(1);
  const [offset, setOffset] = useState({ x: 0, y: 0 });
  const [isDragging, setIsDragging] = useState(false);
  const [dragStart, setDragStart] = useState({ x: 0, y: 0 });
  const [imgSize, setImgSize] = useState({ w: 0, h: 0 });
  const CROP_SIZE = 250; 

  const onImgLoad = (e) => {
    const { naturalWidth, naturalHeight } = e.target;
    setImgSize({ w: naturalWidth, h: naturalHeight });
    const baseScale = Math.max(CROP_SIZE / naturalWidth, CROP_SIZE / naturalHeight);
    setOffset({
      x: (CROP_SIZE - (naturalWidth * baseScale)) / 2,
      y: (CROP_SIZE - (naturalHeight * baseScale)) / 2
    });
  };

  const baseScale = Math.max(CROP_SIZE / (imgSize.w || 1), CROP_SIZE / (imgSize.h || 1));
  const currentScale = baseScale * zoom;
  const dispW = imgSize.w * currentScale;
  const dispH = imgSize.h * currentScale;
  
  useEffect(() => {
    if (imgSize.w === 0) return;
    setOffset(prev => ({
      x: Math.min(0, Math.max(prev.x, CROP_SIZE - dispW)),
      y: Math.min(0, Math.max(prev.y, CROP_SIZE - dispH))
    }));
  }, [zoom, dispW, dispH, imgSize.w]);
  
  const handleStart = (clientX, clientY) => {
    setIsDragging(true);
    setDragStart({ x: clientX - offset.x, y: clientY - offset.y });
  };
  
  const handleMove = (clientX, clientY) => {
    if (!isDragging) return;
    let newX = clientX - dragStart.x;
    let newY = clientY - dragStart.y;
    newX = Math.min(0, Math.max(newX, CROP_SIZE - dispW));
    newY = Math.min(0, Math.max(newY, CROP_SIZE - dispH));
    setOffset({ x: newX, y: newY });
  };

  const handleEnd = () => setIsDragging(false);
  
  const applyCrop = () => {
    const canvas = document.createElement('canvas');
    canvas.width = 400; 
    canvas.height = 400;
    const ctx = canvas.getContext('2d');

    const sw = CROP_SIZE / currentScale;
    const sh = CROP_SIZE / currentScale;
    const sx = -offset.x / currentScale;
    const sy = -offset.y / currentScale;

    const img = new Image();
    if (!imageSrc.startsWith('data:')) {
      img.crossOrigin = "anonymous";
    }
    
    img.onload = () => {
      ctx.drawImage(img, sx, sy, sw, sh, 0, 0, 400, 400);
      onCrop(canvas.toDataURL('image/jpeg', 0.95));
    };
    img.src = imageSrc;
  };

  return (
    <div className="fixed inset-0 bg-slate-900/80 z-[9999] flex items-center justify-center p-4 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm flex flex-col items-center gap-6 animate-in zoom-in-95 duration-200">
        <div className="w-full flex justify-between items-center border-b pb-3">
          <h3 className="font-bold text-gray-800 flex items-center gap-2"><Crop size={18}/> Sesuaikan Foto</h3>
          <button onClick={onClose} className="text-gray-400 hover:text-red-500"><X size={20}/></button>
        </div>

        <div 
          className="relative overflow-hidden bg-gray-100 rounded-2xl cursor-move touch-none border shadow-inner"
          style={{ width: CROP_SIZE, height: CROP_SIZE }}
          onMouseDown={e => handleStart(e.clientX, e.clientY)}
          onMouseMove={e => handleMove(e.clientX, e.clientY)}
          onMouseUp={handleEnd}
          onMouseLeave={handleEnd}
          onTouchStart={e => handleStart(e.touches[0].clientX, e.touches[0].clientY)}
          onTouchMove={e => handleMove(e.touches[0].clientX, e.touches[0].clientY)}
          onTouchEnd={handleEnd}
        >
          <img 
            src={imageSrc} 
            alt="Upload" 
            onLoad={onImgLoad}
            className="absolute top-0 left-0 origin-top-left pointer-events-none max-w-none"
            style={{ transform: `translate(${offset.x}px, ${offset.y}px) scale(${currentScale})`, width: imgSize.w, height: imgSize.h }}
          />
          <div className="absolute inset-0 pointer-events-none shadow-[0_0_0_9999px_rgba(255,255,255,0.4)] rounded-full border border-white/50"></div>
        </div>

        <div className="w-full space-y-2">
          <div className="flex justify-between text-xs font-bold text-gray-500">
            <span>Zoom</span>
