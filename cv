    } else {
      if (audioRef.current) {
        audioRef.current.pause();
        audioRef.current = null;
      }
      
      setSpeakingId(id);
      setLoading(p => ({ ...p, [`speech_${id}`]: true }));
      
      try {
        const inlineData = await callGeminiTTS(text, settings.language);
        let sampleRate = 24000;
        const rateMatch = inlineData.mimeType.match(/rate=(\d+)/);
        if (rateMatch) {
          sampleRate = parseInt(rateMatch[1], 10);
        }
        
        const wavUrl = pcmToWav(inlineData.data, sampleRate);
        const audio = new Audio(wavUrl);
        audioRef.current = audio;
        
        audio.onended = () => {
          setSpeakingId(null);
          audioRef.current = null;
        };
        
        audio.play();
      } catch (err) {
        console.error(err);
        showToast(settings.language === 'id' ? "Gagal memuat suara AI." : "Failed to load AI Voice.", "error");
