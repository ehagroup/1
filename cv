const pcmToWav = (base64PCM, sampleRate = 24000) => {
  const binaryString = window.atob(base64PCM);
  const len = binaryString.length;
  const bytes = new Uint8Array(len);
  for (let i = 0; i < len; i++) {
    bytes[i] = binaryString.charCodeAt(i);
  }
  const buffer = bytes.buffer;

  const numChannels = 1;
  const bitsPerSample = 16;
  const byteRate = (sampleRate * numChannels * bitsPerSample) / 8;
  const blockAlign = (numChannels * bitsPerSample) / 8;
  const dataSize = buffer.byteLength;
  const bufferWav = new ArrayBuffer(44 + dataSize);
  const view = new DataView(bufferWav);
  const writeString = (view, offset, string) => {
    for (let i = 0; i < string.length; i++) {
      view.setUint8(offset + i, string.charCodeAt(i));
    }
  };

  writeString(view, 0, 'RIFF');
  view.setUint32(4, 36 + dataSize, true);
  writeString(view, 8, 'WAVE');
  writeString(view, 12, 'fmt ');
  view.setUint32(16, 16, true);
  view.setUint16(20, 1, true);
  view.setUint16(22, numChannels, true);
  view.setUint32(24, sampleRate, true);
  view.setUint32(28, byteRate, true);
  view.setUint16(32, blockAlign, true);
  view.setUint16(34, bitsPerSample, true);
  writeString(view, 36, 'data');
  view.setUint32(40, dataSize, true);

  new Uint8Array(bufferWav, 44).set(new Uint8Array(buffer));
  const blob = new Blob([bufferWav], { type: 'audio/wav' });
  return URL.createObjectURL(blob);
};

const parseToHtmlList = (text) => {
  if (!text) return "";
  if (text.includes('<ul>') || text.includes('<li>') || text.includes('<div>')) return text;
  const lines = text.split('\n');
  let inList = false;
  let html = "";
  lines.forEach(line => {
      const t = line.trim();
      if (t.startsWith('- ') || t.startsWith('• ') || t.startsWith('* ')) {
          if (!inList) { html += '<ul>'; inList = true; }
          html += `<li>${t.substring(2)}</li>`;
      } else {
          if (inList) { html += '</ul>'; inList = false; }
          html += `<div>${t || '<br>'}</div>`;
      }
  });
  if (inList) html += '</ul>';
  return html.replace(/<div><br><\/div>/g, '<br>');
};

